{
  "info": {
    "_postman_id": "98759362-7724-4ee8-93bb-5d267faeac24",
    "name": "Creator Card Microservice",
    "description": "Repeatable assessment collection for the Creator Card Microservice. Run requests in collection order. The first request creates a unique run_id and later requests reuse captured slugs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('run_id')) {",
          "  pm.collectionVariables.set('run_id', Date.now().toString());",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "run_id",
      "value": ""
    },
    {
      "key": "public_slug",
      "value": ""
    },
    {
      "key": "generated_slug",
      "value": ""
    },
    {
      "key": "private_slug",
      "value": ""
    },
    {
      "key": "draft_slug",
      "value": ""
    },
    {
      "key": "deleted_slug",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Valid assessment cases",
      "item": [
        {
          "name": "01 - Full public card creation",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('run_id', Date.now().toString());",
                  "pm.collectionVariables.unset('public_slug');",
                  "pm.collectionVariables.unset('generated_slug');",
                  "pm.collectionVariables.unset('private_slug');",
                  "pm.collectionVariables.unset('draft_slug');",
                  "pm.collectionVariables.unset('deleted_slug');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Create success envelope', () => {",
                  "  pm.expect(body.status).to.eql('success');",
                  "  pm.expect(body.message).to.eql('Creator Card Created Successfully.');",
                  "});",
                  "pm.test('Exposes id and never _id', () => {",
                  "  pm.expect(body.data.id).to.be.a('string');",
                  "  pm.expect(body.data).not.to.have.property('_id');",
                  "});",
                  "pm.test('Defaults to public and includes null access_code', () => {",
                  "  pm.expect(body.data.access_type).to.eql('public');",
                  "  pm.expect(body.data.access_code).to.eql(null);",
                  "});",
                  "pm.collectionVariables.set('public_slug', body.data.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"George Cooks {{run_id}}\",\n  \"description\": \"Weekly cooking podcast\",\n  \"slug\": \"george-cooks-{{run_id}}\",\n  \"creator_reference\": \"crt_8f2k1m9x4p7w3q5z\",\n  \"links\": [\n    {\n      \"title\": \"YouTube\",\n      \"url\": \"https://youtube.com/@georgecooks\"\n    }\n  ],\n  \"service_rates\": {\n    \"currency\": \"NGN\",\n    \"rates\": [\n      {\n        \"name\": \"IG Story Post\",\n        \"description\": \"One story mention\",\n        \"amount\": 5000000\n      }\n    ]\n  },\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/creator-cards",
              "host": ["{{base_url}}"],
              "path": ["creator-cards"]
            },
            "description": "Creates a complete published public card and stores its slug for later requests."
          }
        },
        {
          "name": "02 - Automatic slug generation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const expectedSlug = `ada-designs-${pm.collectionVariables.get('run_id')}`;",
                  "pm.test('Slug is generated from title', () => pm.expect(body.data.slug).to.eql(expectedSlug));",
                  "pm.collectionVariables.set('generated_slug', body.data.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Ada Designs {{run_id}}\",\n  \"creator_reference\": \"crt_a1b2c3d4e5f6g7h8\",\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/creator-cards",
              "host": ["{{base_url}}"],
              "path": ["creator-cards"]
            }
          }
        },
